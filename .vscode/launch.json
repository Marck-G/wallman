{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Wallman (Daemon)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/wallman",
            "args": ["daemon", "start", "--debug", "--foreground"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cargo build"
        },
        {
            "name": "Debug Wallman (CLI)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/wallman",
            "args": ["--help"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cargo build"
        },
        {
            "name": "Debug Wallman (Theme Pack)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/wallman",
            "args": ["pack", "example/moon-wall"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cargo build"
        },
        {
            "name": "Debug Wallman (Theme Install)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/wallman",
            "args": ["theme", "install", "example/moon-wall"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cargo build"
        },
        {
            "name": "Debug Wallman (Config)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/wallman",
            "args": ["config", "show"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cargo build"
        }
    ]
}
